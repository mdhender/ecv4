// Copy this into your server wiring after running `make generate` and copying
// server.go.stub to server.go.

package handlers

import (
	"net/http"

	"example.com/go-game-server/internal/api"
)

func NewHTTPHandler(server *Server) http.Handler {
	mux := http.NewServeMux()
	strict := api.NewStrictHandler(server, nil)
	return api.HandlerFromMux(strict, mux)
}
